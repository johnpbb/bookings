# ── Database ────────────────────────────────────────────────────────────────
# Provided by Opalstack PostgreSQL — format: postgresql://user:pass@host:5432/dbname
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/tahi_bookings"

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://book.tahitonga.com"
NODE_ENV="development"

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-generated-secret"
NEXTAUTH_URL="http://localhost:3000"

# ── ANZ eGate (stored in DB settings, but can override here) ─────────────────
# Leave blank — configure in Admin > Settings instead.
# EGATE_MERCHANT_ID=
# EGATE_SHARED_SECRET=

# ── SMTP Email ──────────────────────────────────────────────────────────────
SMTP_HOST="mail.yourdomain.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="bookings@tahitonga.com"
SMTP_PASS="your-email-password"
SMTP_FROM="bookings@tahitonga.com"

# ── Cron Secret ─────────────────────────────────────────────────────────────
# Used to authenticate cron job HTTP requests
# Generate with: openssl rand -hex 32
CRON_SECRET="replace-with-generated-cron-secret"
